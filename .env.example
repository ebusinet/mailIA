# MailIA Configuration

# --- Database ---
POSTGRES_DB=mailia
POSTGRES_USER=mailia
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://mailia:CHANGE_ME_STRONG_PASSWORD@postgres:5432/mailia

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://elasticsearch:9200

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
CELERY_BROKER_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/1

# --- Tika ---
TIKA_URL=http://tika:9998

# --- Security ---
SECRET_KEY=CHANGE_ME_RANDOM_64_CHARS
ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY

# --- Telegram ---
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER

# --- AI Providers (defaults, users can override) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- App ---
APP_URL=https://mailia.expert-presta.com
APP_NAME=MailIA
LOG_LEVEL=info
